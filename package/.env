# Dev-only environment values for the package template app.
# These paths resolve relative to the package/ folder during local development.
# This file is NOT included in exported ZIP packages — the packaging tool
# replaces the token strings in src/App.jsx directly before export.
VITE_SOUNDSCAPE_AUDIO=./audio/example.mp3
VITE_SOUNDSCAPE_DATA=./data/soundscape.json
VITE_SOUNDSCAPE_METADATA=./data/metadata.json
